APP_NAME=Selloff
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
FRONTEND_URL=http://localhost:5173
SPA_URL="${FRONTEND_URL}"
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=selloff
DB_USERNAME=homestead
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@selloff.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Optional CloudFront or custom CDN base (overrides default bucket URL for public reads)
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Legacy production images live on S3. For local dev after Pass 11 import:
#   1) Set AWS_BUCKET + AWS_DEFAULT_REGION to match production (required for image URLs)
#   2) Set AWS_URL if production uses CloudFront
#   3) AWS_ACCESS_KEY_ID/SECRET only needed for new uploads — not for displaying public objects
#   4) SELLOFF_MEDIA_DISK=s3 if vendors should upload to S3 locally (optional)
# Legacy DB stores `202604/img_….webp`; S3 keys are `uploads/images/202604/…` (auto-prefixed in API URLs)
SELLOFF_LEGACY_PRODUCT_IMAGE_PREFIX=uploads/images
SELLOFF_IMAGE_URL_PREFIX=/storage/
SELLOFF_MEDIA_DISK=public
# Fallbacks only — runtime reads image_file_format and watermark_* from platform_settings first.
SELLOFF_IMAGE_FILE_FORMAT=WEBP
SELLOFF_WATERMARK_PRODUCT=false
SELLOFF_WATERMARK_BLOG=false
SELLOFF_WATERMARK_THUMBNAIL=false
SELLOFF_WATERMARK_TEXT=

# OAuth (Pass 1 — configure per provider)
# Google rejects .local redirect URIs (e.g. api.selloff.local). For local dev with Vite proxy:
#   GOOGLE_REDIRECT_URI=http://localhost:5173/api/v1/auth/oauth/google/callback
# Register that exact URI in Google Cloud Console → Credentials → OAuth client → Authorized redirect URIs.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Payments (Pass 4)
SELLOFF_WALLET_ENABLED=true
SELLOFF_BANK_TRANSFER_ENABLED=true
SELLOFF_BANK_TRANSFER_INSTRUCTIONS="Transfer to Selloff Demo Bank — Acct 0123456789"
SELLOFF_COD_ENABLED=true
SELLOFF_STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
SELLOFF_STRIPE_VERIFY_WEBHOOK=true
STRIPE_SUCCESS_URL="${FRONTEND_URL}/orders?stripe=success"
STRIPE_CANCEL_URL="${FRONTEND_URL}/cart?stripe=cancelled"

# Seeding
# Essential only:
#   php artisan selloff:migrate --fresh --seed
# Full refresh with demo users (local dev):
#   RUN_DEMO_SEEDER=true php artisan selloff:migrate --fresh --seed
RUN_DEMO_SEEDER=false
# Disable Cloudflare Turnstile on login/register/contact (overrides imported platform_settings).
SELLOFF_TURNSTILE_DISABLED=true
APP_SUPERADMIN_EMAIL=superadmin@selloff.test
APP_SUPERADMIN_PASSWORD=password
# Bootstrap global Super Admin PIN when missing (local default: 196001). Legacy import also runs this.
SUPER_ADMIN_BOOTSTRAP_PIN=196001
APP_DEMO_VENDOR_EMAIL=vendor@selloff.test
APP_DEMO_VENDOR_PASSWORD=password
APP_DEMO_VENDOR2_EMAIL=vendor2@selloff.test
APP_DEMO_VENDOR2_PASSWORD=password
APP_DEMO_MEMBER_EMAIL=buyer@selloff.test
APP_DEMO_MEMBER_PASSWORD=password

# Additional demo vendors (password: password)
# vendor3@selloff.test — Lagos Home & Living
# vendor4@selloff.test — Glow Beauty NG
# vendor5@selloff.test — FitLife Sports
# vendor6@selloff.test — PageTurner Books

# Legacy ETL (Phase 17 / Pass 11 cutover)
SELLOFF_LEGACY_DUMP=../docs/data/production-mysql-dump.sql
SELLOFF_ETL_MEMORY_LIMIT=1G
SELLOFF_ETL_MAINTENANCE_WINDOW_SECONDS=14400
SELLOFF_ETL_VERIFY_IMAGE_SAMPLE=100

VITE_APP_NAME="${APP_NAME}"
