{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-bcmath": "*",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^3.0",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-permission": "^7.4",
        "stripe/stripe-php": "^20.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Modules\\Selloff\\Core\\": "packages/selloff/Core/src/",
            "App\\Modules\\Selloff\\User\\": "packages/selloff/User/src/",
            "App\\Modules\\Selloff\\Location\\": "packages/selloff/Location/src/",
            "App\\Modules\\Selloff\\Catalog\\": "packages/selloff/Catalog/src/",
            "App\\Modules\\Selloff\\Vendor\\": "packages/selloff/Vendor/src/",
            "App\\Modules\\Selloff\\Cart\\": "packages/selloff/Cart/src/",
            "App\\Modules\\Selloff\\Order\\": "packages/selloff/Order/src/",
            "App\\Modules\\Selloff\\Payment\\": "packages/selloff/Payment/src/",
            "App\\Modules\\Selloff\\Shipping\\": "packages/selloff/Shipping/src/",
            "App\\Modules\\Selloff\\Payout\\": "packages/selloff/Payout/src/",
            "App\\Modules\\Selloff\\Promotion\\": "packages/selloff/Promotion/src/",
            "App\\Modules\\Selloff\\Review\\": "packages/selloff/Review/src/",
            "App\\Modules\\Selloff\\Escrow\\": "packages/selloff/Escrow/src/",
            "App\\Modules\\Selloff\\Affiliate\\": "packages/selloff/Affiliate/src/",
            "App\\Modules\\Selloff\\Referral\\": "packages/selloff/Referral/src/",
            "App\\Modules\\Selloff\\Notification\\": "packages/selloff/Notification/src/",
            "App\\Modules\\Selloff\\Media\\": "packages/selloff/Media/src/",
            "App\\Modules\\Selloff\\Content\\": "packages/selloff/Content/src/",
            "App\\Modules\\Selloff\\Support\\": "packages/selloff/Support/src/",
            "App\\Modules\\Selloff\\Messaging\\": "packages/selloff/Messaging/src/",
            "App\\Modules\\Selloff\\Admin\\": "packages/selloff/Admin/src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "./vendor/bin/pest"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.28"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
